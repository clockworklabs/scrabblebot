{
  "name": "wordsmith",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "spacetime generate --lang typescript --out-dir src/module_bindings --module-path ./spacetimedb",
    "publish": "spacetime publish --module-path ./spacetimedb",
    "dev": "spacetime dev --server maincloud --delete-data on-conflict -y",
    "dev:client": "vite",
    "dev:local": "spacetime dev --server local --delete-data on-conflict -y",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.17.0",
    "spacetimedb": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0"
  }
}
