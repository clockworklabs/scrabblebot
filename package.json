{
  "name": "wordsmith",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "spacetime generate --lang typescript --out-dir src/module_bindings --module-path ./spacetimedb",
    "publish": "spacetime publish wordsmith --module-path ./spacetimedb",
    "dev": "spacetime dev --server local -y",
    "dev:client": "vite",
    "dev:cloud": "spacetime dev --server maincloud -y",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "spacetimedb": "2.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0"
  }
}
